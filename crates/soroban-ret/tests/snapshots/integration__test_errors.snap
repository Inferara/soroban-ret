#![no_std]
use soroban_sdk::{
    contract, contracterror, contractimpl, contracttype, panic_with_error, symbol_short, Env,
    Symbol,
};
#[contracttype]
#[derive(Debug, Copy, Clone, Eq, PartialEq, Ord, PartialOrd)]
pub enum Flag {
    A = 0,
    B = 1,
    C = 2,
    D = 3,
    E = 4,
}
#[contracterror]
#[derive(Debug, Copy, Clone, Eq, PartialEq, Ord, PartialOrd)]
pub enum Error {
    AnError = 1,
}
#[contract]
pub struct Contract;
#[contractimpl]
impl Contract {
    pub fn hello(env: Env, flag: Flag) -> Result<Symbol, Error> {
        env.storage()
            .persistent()
            .set(&symbol_short!("persisted"), &1);
        if flag == Flag::A {
            Ok(symbol_short!("hello"))
        } else if flag == Flag::C {
            Err(Error::AnError)
        } else if flag == Flag::D {
            panic!()
        } else {
            panic_with_error!(&env, soroban_sdk::Error::from_contract_error(9))
        }
    }
}
